# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_management
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=10

# ── JWT ────────────────────────────────────────────────────────────────────
# IMPORTANT: replace with a long, random secret in production
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=1h

# ── Bcrypt ─────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ── Logging ────────────────────────────────────────────────────────────────
# Levels: info | debug
LOG_LEVEL=info
